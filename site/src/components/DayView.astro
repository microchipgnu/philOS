---
import { getReport, getDayThreads, getDayVideo, type DayIndex } from "../lib/reports";
import { buildDayGraph } from "../lib/graph";
import DayGraph from "./DayGraph.astro";

interface Props {
  day: DayIndex;
  prevDate: string | null;
  nextDate: string | null;
}

const { day, prevDate, nextDate } = Astro.props;

let leadBrief: string | null = null;
if (day.reports.length > 0) {
  const lead = getReport(day.date, day.reports[0].id);
  if (lead) {
    const bl = lead.brief.bottomLine;
    leadBrief = bl.length > 160 ? bl.slice(0, 157).replace(/\s+\S*$/, "") + "..." : bl;
  }
}

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + "T12:00:00Z");
  return d.toLocaleDateString("en-US", { weekday: "long", month: "long", day: "numeric", year: "numeric" });
}

function shortDate(dateStr: string): string {
  const d = new Date(dateStr + "T12:00:00Z");
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
}

const d = new Date(day.date + "T12:00:00Z");
const dayNum = d.getDate();
const monthName = d.toLocaleDateString("en-US", { month: "long" });
const yearNum = d.getFullYear();
const weekday = d.toLocaleDateString("en-US", { weekday: "long" });

const graph = buildDayGraph(day.date);
const dayVideo = getDayVideo(day.date);
const dayThreads = getDayThreads(day.date);

const typeLabels: Record<string, string> = {
  "cause-effect": "Cause & Effect",
  "dependency-web": "Hidden Dependencies",
  "tension-cluster": "Same Question",
};

const rest = day.reports.slice(1);
const hasOddRest = rest.length % 2 !== 0;
const gridItems = hasOddRest ? rest.slice(0, -1) : rest;
const lastItem = hasOddRest ? rest[rest.length - 1] : null;
---

<!-- Calendar header -->
<header class="border-b border-[var(--color-border)] py-8">
  <div class="flex items-center justify-between">
    {prevDate ? (
      <a href={`/day/${prevDate}`} class="flex items-center gap-1 text-[13px] font-medium text-[var(--color-text-tertiary)] hover:text-[var(--color-text)]">
        <span class="text-[18px]">&larr;</span>
        <span>{shortDate(prevDate)}</span>
      </a>
    ) : (
      <span />
    )}
    <div class="text-center">
      <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)]">{weekday}</p>
      <p class="mt-1 font-serif text-[56px] leading-none">{dayNum}</p>
      <p class="mt-1 text-[13px] text-[var(--color-text-tertiary)]">{monthName} {yearNum}</p>
    </div>
    {nextDate ? (
      <a href={`/day/${nextDate}`} class="flex items-center gap-1 text-[13px] font-medium text-[var(--color-text-tertiary)] hover:text-[var(--color-text)]">
        <span>{shortDate(nextDate)}</span>
        <span class="text-[18px]">&rarr;</span>
      </a>
    ) : (
      <a href="/" class="text-[13px] font-medium text-[var(--color-accent)] hover:text-[var(--color-text)]">today</a>
    )}
  </div>
</header>

{graph && <DayGraph graph={graph} />}

{day.reports.length > 0 && (
  <!-- Hero: lead story -->
  <a
    href={`/report/${day.date}/${day.reports[0].id}`}
    class="group block border-b border-[var(--color-border)] py-8"
  >
    <div class="flex items-baseline gap-3">
      {day.reports[0].topic && (
        <span class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)]">
          {day.reports[0].topic}
        </span>
      )}
      <span class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">
        {day.reports[0].category}
      </span>
    </div>
    <h2 class="mt-3 font-serif text-[40px] leading-[1.1] group-hover:text-[var(--color-accent)]">
      {day.reports[0].title}
    </h2>
    {leadBrief && (
      <p class="mt-3 max-w-2xl font-serif text-[19px] italic leading-snug text-[var(--color-text-secondary)]">
        {leadBrief}
      </p>
    )}
  </a>
)}

{gridItems.length > 0 && (
  <!-- Paired stories in 2-col grid -->
  <div class="grid border-b border-[var(--color-border)] md:grid-cols-2">
    {gridItems.map((r, i) => (
      <a
        href={`/report/${day.date}/${r.id}`}
        class:list={[
          "group block p-6 transition-colors hover:bg-[var(--color-surface-warm)]",
          i % 2 === 0 && "md:border-r md:border-[var(--color-border)]",
          i < gridItems.length - 2 && "border-b border-[var(--color-border)]",
        ]}
      >
        <div class="flex items-baseline gap-3">
          {r.topic && (
            <span class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)]">
              {r.topic}
            </span>
          )}
          <span class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">
            {r.category}
          </span>
        </div>
        <h3 class="mt-2 font-serif text-[22px] leading-tight group-hover:text-[var(--color-accent)]">
          {r.title}
        </h3>
        <p class="mt-2 text-[14px] leading-relaxed text-[var(--color-text-secondary)]">
          {r.subtitle}
        </p>
      </a>
    ))}
  </div>
)}

{lastItem && (
  <!-- Orphan story: full width -->
  <a
    href={`/report/${day.date}/${lastItem.id}`}
    class="group block border-b border-[var(--color-border)] p-6 transition-colors hover:bg-[var(--color-surface-warm)]"
  >
    <div class="flex items-baseline gap-3">
      {lastItem.topic && (
        <span class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)]">
          {lastItem.topic}
        </span>
      )}
      <span class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">
        {lastItem.category}
      </span>
    </div>
    <h3 class="mt-2 font-serif text-[22px] leading-tight group-hover:text-[var(--color-accent)]">
      {lastItem.title}
    </h3>
    <p class="mt-2 text-[14px] leading-relaxed text-[var(--color-text-secondary)]">
      {lastItem.subtitle}
    </p>
  </a>
)}

{dayThreads && dayThreads.threads.length > 0 && (
  <section class="py-10">
    <h2 class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">Threads</h2>
    <p class="mt-1 text-[13px] text-[var(--color-text-tertiary)]">Connections you won't see in any single story</p>
    <div class="mt-6 space-y-5">
      {dayThreads.threads.map((thread) => (
        <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-warm)] p-5">
          <span class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">{typeLabels[thread.type] || thread.type}</span>
          <p class="mt-2 font-serif text-[20px] leading-snug">{thread.title}</p>
          <p class="mt-2 text-[14px] leading-relaxed text-[var(--color-text-secondary)]">{thread.description}</p>
          <div class="mt-4 space-y-2">
            {thread.connections.map((conn) => (
              <div class="flex items-start gap-2 text-[13px]">
                <span class="mt-0.5 text-[var(--color-accent)]">→</span>
                <p class="text-[var(--color-text-tertiary)]">
                  <a href={`/report/${day.date}/${conn.from}`} class="font-medium text-[var(--color-text)] hover:text-[var(--color-accent)]">{conn.from}</a>
                  {" → "}
                  <a href={`/report/${day.date}/${conn.to}`} class="font-medium text-[var(--color-text)] hover:text-[var(--color-accent)]">{conn.to}</a>
                  {": "}{conn.relationship}
                </p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
)}
