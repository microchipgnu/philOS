---
import Base from "../../layouts/Base.astro";
import { getAllReports, getReport } from "../../lib/reports";

export function getStaticPaths() {
  const all = getAllReports();
  return all.map(({ date, slug }) => ({
    params: { slug: `${date}/${slug}` },
    props: { date, slug },
  }));
}

const { date, slug } = Astro.props;
const report = getReport(date, slug);
if (!report) return Astro.redirect("/");

const { brief } = report;
---

<Base title={report.title} description={report.subtitle}>
  <article class="mx-auto max-w-2xl">

    <!-- Header -->
    <div class="mb-2 flex items-center gap-3">
      <span class="rounded bg-[var(--color-surface-overlay)] px-2 py-0.5 text-xs uppercase tracking-wider text-[var(--color-text-muted)]">
        {report.category}
      </span>
      <span class="text-xs text-[var(--color-text-dim)]">{report.date}</span>
    </div>
    <h1 class="font-serif text-3xl font-bold leading-tight">{report.title}</h1>

    <!-- Bottom line -->
    <p class="mt-6 border-l-2 border-[var(--color-text-dim)] pl-4 text-lg leading-relaxed text-[var(--color-text-muted)]">
      {brief.bottomLine}
    </p>

    <!-- Hidden bets -->
    <section class="mt-10">
      <h2 class="mb-4 text-xs font-semibold uppercase tracking-widest text-[var(--color-text-dim)]">The Hidden Bet</h2>
      <div class="space-y-5">
        {brief.hiddenBets.map((bet) => (
          <div>
            <p class="font-medium">{bet.assumption}</p>
            <p class="mt-1 text-sm leading-relaxed text-[var(--color-text-muted)]">{bet.whyItMightBeWrong}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Real disagreement -->
    <section class="mt-10">
      <h2 class="mb-4 text-xs font-semibold uppercase tracking-widest text-[var(--color-text-dim)]">The Real Disagreement</h2>
      <p class="leading-relaxed">{brief.realDisagreement}</p>
    </section>

    <!-- What no one is saying -->
    {brief.whatNoOneIsSaying && (
      <section class="mt-10">
        <h2 class="mb-4 text-xs font-semibold uppercase tracking-widest text-[var(--color-text-dim)]">What No One Is Saying</h2>
        <p class="leading-relaxed">{brief.whatNoOneIsSaying}</p>
      </section>
    )}

    <!-- Who pays -->
    <section class="mt-10">
      <h2 class="mb-4 text-xs font-semibold uppercase tracking-widest text-[var(--color-text-dim)]">Who Pays</h2>
      <div class="space-y-4">
        {brief.whoPays.map((p) => (
          <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-raised)] p-4">
            <p class="text-sm font-bold">{p.who}</p>
            <p class="mt-1 text-sm leading-relaxed text-[var(--color-text-muted)]">{p.how}</p>
            <p class="mt-1 text-xs text-[var(--color-text-dim)]">{p.when}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Scenarios -->
    <section class="mt-10">
      <h2 class="mb-4 text-xs font-semibold uppercase tracking-widest text-[var(--color-text-dim)]">Scenarios</h2>
      <div class="space-y-4">
        {brief.scenarios.map((sc) => (
          <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-raised)] p-4">
            <p class="text-sm font-bold">{sc.name}</p>
            <p class="mt-1 text-sm leading-relaxed text-[var(--color-text-muted)]">{sc.whatHappens}</p>
            <p class="mt-2 text-xs text-[var(--color-text-dim)]"><span class="font-semibold">Signal:</span> {sc.signal}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- What would change this -->
    <section class="mt-10">
      <h2 class="mb-4 text-xs font-semibold uppercase tracking-widest text-[var(--color-text-dim)]">What Would Change This</h2>
      <p class="leading-relaxed">{brief.whatWouldChange}</p>
    </section>

    <!-- Sources -->
    <section class="mt-10 border-t border-[var(--color-border)] pt-6">
      <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-[var(--color-text-dim)]">Sources</h2>
      <div class="space-y-1">
        {report.sources.map((s) => (
          <div class="flex items-baseline gap-2 text-sm">
            <a href={s.url} target="_blank" rel="noopener" class="font-medium hover:underline">{s.publisher}</a>
            <span class="text-xs text-[var(--color-text-dim)]">— {s.angle}</span>
          </div>
        ))}
      </div>
    </section>

    <div class="mt-10">
      <a href="/" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)]">&larr; Back</a>
    </div>
  </article>
</Base>
