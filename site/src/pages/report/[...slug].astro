---
import Base from "../../layouts/Base.astro";
import { getAllReports, getReport, getRelatedBriefs } from "../../lib/reports";

export function getStaticPaths() {
  const all = getAllReports();
  return all.map(({ date, slug }) => ({
    params: { slug: `${date}/${slug}` },
    props: { date, slug },
  }));
}

const { date, slug } = Astro.props;
const report = getReport(date, slug);
if (!report) return Astro.redirect("/");

const { brief } = report;
const related = getRelatedBriefs(report);

function tagSlug(tag: string): string {
  return tag.toLowerCase().replace(/\s+/g, "-");
}

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + "T12:00:00Z");
  return d.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });
}

let ogDescription = report.subtitle;
if (ogDescription.length < 110) {
  const extra = " " + brief.bottomLine;
  ogDescription = (ogDescription + extra).slice(0, 160);
  if (ogDescription.length < ogDescription.length + extra.length) {
    ogDescription = ogDescription.replace(/\s+\S*$/, "...");
  }
}

const sections = [
  { id: "context", label: "Context" },
  brief.hiddenBets?.length && { id: "bets", label: "Hidden Bets" },
  brief.realDisagreement && { id: "disagreement", label: "Disagreement" },
  brief.whatNoOneIsSaying && { id: "unsaid", label: "Unsaid" },
  brief.whoPays?.length && { id: "whopays", label: "Who Pays" },
  brief.scenarios?.length && { id: "scenarios", label: "Scenarios" },
  brief.whatWouldChange && { id: "change", label: "What Would Change" },
  brief.markets?.length && { id: "markets", label: "Markets" },
].filter(Boolean) as { id: string; label: string }[];
---

<Base title={report.title} description={ogDescription} ogImage={`/og/${date}/${slug}.png`}>
  <article class="py-10">

    <!-- Nav bar -->
    <div class="mb-8 flex items-center justify-between text-[13px]">
      <a href={`/day/${date}`} class="font-medium text-[var(--color-text-tertiary)] hover:text-[var(--color-text)]">&larr; {formatDate(date)}</a>
      <div class="flex items-baseline gap-3">
        {report.topic && (
          <span class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)]">{report.topic}</span>
        )}
        <span class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">{report.category}</span>
      </div>
    </div>

    <!-- Title -->
    <h1 class="font-serif text-[38px] leading-[1.1] md:text-[42px]">{report.title}</h1>

    <!-- Cover image -->
    {report.coverImage && (
      <figure class="mt-6">
        <img
          src={report.coverImage.local}
          alt={report.title}
          class="w-full rounded-lg object-cover"
          style="max-height: 400px;"
          loading="eager"
        />
        <figcaption class="mt-2 text-[11px] text-[var(--color-text-tertiary)]">
          {report.coverImage.credit}
        </figcaption>
      </figure>
    )}

    <!-- What happened — context block -->
    {brief.whatHappened && (
      <div id="context" class="mt-6 rounded-lg bg-[var(--color-surface-warm)] p-5">
        <p class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)]">What happened</p>
        <p class="mt-2 text-[15px] leading-relaxed text-[var(--color-text-secondary)]">
          {brief.whatHappened}
        </p>
      </div>
    )}

    <!-- Bottom line — pull quote style -->
    <blockquote class="mt-8 border-l-[3px] border-[var(--color-accent)] pl-5">
      <p class="font-serif text-[21px] italic leading-snug text-[var(--color-text)]">
        {brief.bottomLine}
      </p>
    </blockquote>

    <!-- Section nav dots -->
    <nav class="mt-10 flex flex-wrap gap-3 border-b border-[var(--color-border)] pb-4">
      {sections.map((s) => (
        <a href={`#${s.id}`} class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)] hover:text-[var(--color-accent)]">
          {s.label}
        </a>
      ))}
    </nav>

    <!-- Hidden bets -->
    {brief.hiddenBets?.length > 0 && (
      <section id="bets" class="mt-10">
        <h2 class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">The Hidden Bet</h2>
        <div class="mt-5 space-y-6">
          {brief.hiddenBets.map((bet, i) => (
            <div class="flex gap-4">
              <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-[var(--color-surface-inset)] text-[11px] font-semibold text-[var(--color-text-tertiary)]">{i + 1}</span>
              <div>
                <p class="text-[16px] font-medium leading-snug">{bet.assumption}</p>
                <p class="mt-2 text-[15px] leading-relaxed text-[var(--color-text-secondary)]">{bet.whyItMightBeWrong}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Real disagreement -->
    {brief.realDisagreement && (
      <section id="disagreement" class="mt-12">
        <h2 class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">The Real Disagreement</h2>
        <p class="mt-5 text-[16px] leading-[1.75]">{brief.realDisagreement}</p>
      </section>
    )}

    <!-- What no one is saying — visually distinct, mobile-safe -->
    {brief.whatNoOneIsSaying && (
      <section id="unsaid" class="my-12 rounded-lg bg-[var(--color-surface-dark)] px-6 py-7 text-[var(--color-surface)] md:px-8 md:py-8">
        <h2 class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">What No One Is Saying</h2>
        <p class="mt-4 font-serif text-[18px] italic leading-relaxed opacity-90">{brief.whatNoOneIsSaying}</p>
      </section>
    )}

    <!-- Who pays -->
    {brief.whoPays?.length > 0 && (
      <section id="whopays" class="mt-10">
        <h2 class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">Who Pays</h2>
        <div class="mt-5 space-y-4">
          {brief.whoPays.map((p) => (
            <div class="rounded-lg border border-[var(--color-border)] p-4">
              <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
                <p class="text-[15px] font-semibold">{p.who}</p>
                <p class="text-[12px] text-[var(--color-text-tertiary)]">{p.when}</p>
              </div>
              <p class="mt-2 text-[14px] leading-relaxed text-[var(--color-text-secondary)]">{p.how}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Scenarios -->
    {brief.scenarios?.length > 0 && (
      <section id="scenarios" class="mt-12">
        <h2 class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">Scenarios</h2>
        <div class="mt-5 space-y-4 md:space-y-0 md:grid md:grid-cols-3 md:gap-px md:overflow-hidden md:rounded-lg md:border md:border-[var(--color-border)] md:bg-[var(--color-border)]">
          {brief.scenarios.map((sc) => (
            <div class="rounded-lg border border-[var(--color-border)] p-5 md:rounded-none md:border-0 md:bg-[var(--color-surface)]">
              <p class="font-serif text-[17px] italic">{sc.name}</p>
              <p class="mt-2 text-[14px] leading-relaxed text-[var(--color-text-secondary)]">{sc.whatHappens}</p>
              <p class="mt-3 border-t border-[var(--color-border)] pt-3 text-[12px] text-[var(--color-text-tertiary)]">
                <span class="font-semibold uppercase tracking-wider">Signal</span> {sc.signal}
              </p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- What would change this -->
    {brief.whatWouldChange && (
      <section id="change" class="mt-12">
        <h2 class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">What Would Change This</h2>
        <p class="mt-4 rounded-lg border border-dashed border-[var(--color-border-strong)] bg-[var(--color-surface-warm)] p-5 text-[15px] leading-relaxed text-[var(--color-text-secondary)]">
          {brief.whatWouldChange}
        </p>
      </section>
    )}

    <!-- Prediction markets -->
    {brief.markets && brief.markets.length > 0 && (
      <section id="markets" class="mt-12">
        <h2 class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">Prediction Markets</h2>
        <p class="mt-1 text-[12px] text-[var(--color-text-tertiary)]">Prices as of {report.date} — the analysis was written against these odds</p>
        <div class="mt-4 space-y-3">
          {brief.markets.map((m) => (
            <a
              href={m.url}
              target="_blank"
              rel="noopener"
              class="group flex items-center justify-between rounded-lg border border-[var(--color-border)] p-4 transition-colors hover:border-[var(--color-accent)]"
            >
              <div class="min-w-0 flex-1">
                <p class="text-[14px] font-medium group-hover:text-[var(--color-accent)]">{m.question}</p>
                <p class="mt-1 text-[12px] text-[var(--color-text-tertiary)]">{m.platform} · as of {report.date}</p>
              </div>
              <div class="ml-4 flex-shrink-0 text-right">
                <p class="text-[24px] font-semibold tabular-nums">{Math.round(m.probability * 100)}%</p>
                <p class="text-[11px] text-[var(--color-text-tertiary)]">yes</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Footer: sources + tags together -->
    <footer class="mt-16 border-t border-[var(--color-border)] pt-8">
      <div class="flex flex-col gap-8 md:flex-row md:gap-16">
        <!-- Sources -->
        <div class="flex-1">
          <h2 class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)]">Sources</h2>
          <div class="mt-3 space-y-1.5">
            {report.sources.map((s) => (
              <div class="text-[13px]">
                <a href={s.url} target="_blank" rel="noopener" class="font-medium text-[var(--color-text)] underline decoration-[var(--color-border)] underline-offset-2 hover:decoration-[var(--color-text)]">{s.publisher}</a>
                <span class="text-[var(--color-text-tertiary)]"> — {s.angle}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Tags -->
        {report.tags.length > 0 && (
          <div class="md:w-48">
            <h2 class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)]">Topics</h2>
            <div class="mt-3 flex flex-wrap gap-2">
              {report.tags.map((tag) => (
                <a
                  href={`/topic/${tagSlug(tag)}`}
                  class="rounded-full border border-[var(--color-border)] px-2.5 py-0.5 text-[11px] text-[var(--color-text-tertiary)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
                >
                  {tag}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </footer>

    <!-- Related briefs -->
    {related.length > 0 && (
      <section class="mt-10 border-t border-[var(--color-border)] pt-8">
        <h2 class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-text-tertiary)]">Related</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-2">
          {related.map((r) => (
            <a
              href={`/report/${r.date}/${r.slug}`}
              class="group block rounded-lg border border-[var(--color-border)] p-4 transition-colors hover:border-[var(--color-accent)]"
            >
              <span class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">{r.category}</span>
              <p class="mt-1 font-serif text-[16px] leading-tight group-hover:text-[var(--color-accent)]">{r.title}</p>
            </a>
          ))}
        </div>
      </section>
    )}

  </article>
</Base>
