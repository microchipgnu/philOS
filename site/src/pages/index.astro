---
import Base from "../layouts/Base.astro";
import { getLatestDay } from "../lib/reports";

const day = getLatestDay();
---

<Base title="Today">
  {!day ? (
    <p class="py-20 text-[var(--color-text-tertiary)]">No reports yet.</p>
  ) : (
    <div class="py-10">
      <div class="mb-10 flex items-baseline justify-between">
        <h1 class="font-serif text-4xl italic">{day.date}</h1>
        <span class="text-[13px] text-[var(--color-text-tertiary)]">{day.reports.length} briefs</span>
      </div>

      {day.reports.map((r, i) => (
        <a
          href={`/report/${day.date}/${r.id}`}
          class:list={[
            "group block border-b border-[var(--color-border)] py-7 transition-colors hover:bg-[var(--color-surface-warm)]",
            i === 0 && "border-t",
          ]}
        >
          <div class="flex items-baseline gap-3">
            <span class="text-[11px] font-semibold uppercase tracking-widest text-[var(--color-accent)]">
              {r.category}
            </span>
          </div>
          <h2 class="mt-2 font-serif text-[28px] leading-tight group-hover:text-[var(--color-accent)]">
            {r.title}
          </h2>
          <p class="mt-2 text-[15px] leading-relaxed text-[var(--color-text-secondary)]">
            {r.subtitle}
          </p>
        </a>
      ))}
    </div>
  )}
</Base>
